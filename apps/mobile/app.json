{
  "expo": {
    "name": "Netra",
    "slug": "guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1526"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.netraops.guard",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "AIzaSyBCBgU60e8PbeZEPeKA7RVddgTlLwy7jiA"
      },
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Netra requires your location to verify you are on-site during shifts.",
        "NSLocationAlwaysUsageDescription": "Netra monitors your location in the background to ensure geofence compliance during your shift.",
        "NSCameraUsageDescription": "Netra uses the camera for clock-in verification and shift reports.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely sign in.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.netraops.guard",
      "versionCode": 7,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBCBgU60e8PbeZEPeKA7RVddgTlLwy7jiA"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1526"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "plugins": [
      "./app.plugin.js",
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Netra monitors your location during shifts for geofence compliance."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Netra uses the camera for clock-in verification and reports."
        }
      ]
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "scheme": "netra",
    "extra": {
      "eas": {
        "projectId": "5fd28125-2461-4165-b9df-7f34ced8b194"
      }
    },
    "owner": "vvishnu1998"
  }
}
