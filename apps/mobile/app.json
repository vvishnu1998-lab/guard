{
  "expo": {
    "name": "V-Wing",
    "slug": "v-wing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vishnu.vwing",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "AIzaSyBCBgU60e8PbeZEPeKA7RVddgTlLwy7jiA"
      },
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "V-Wing requires your location to verify you are on-site during shifts.",
        "NSLocationAlwaysUsageDescription": "V-Wing monitors your location in the background to ensure geofence compliance during your shift.",
        "NSCameraUsageDescription": "V-Wing uses the camera for clock-in verification and shift reports.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely sign in."
      }
    },
    "android": {
      "package": "com.vishnu.vwing",
      "versionCode": 1,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBCBgU60e8PbeZEPeKA7RVddgTlLwy7jiA"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "./app.plugin.js",
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "V-Wing monitors your location during shifts for geofence compliance."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "V-Wing uses the camera for clock-in verification and reports."
        }
      ]
    ],
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "scheme": "v-wing",
    "extra": {
      "eas": {
        "projectId": "5fd28125-2461-4165-b9df-7f34ced8b194"
      }
    }
  }
}
