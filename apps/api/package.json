{
  "name": "@v-wing/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "PATH=/opt/homebrew/bin:$PATH ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts dotenv_config_path=../../.env",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "ts-node --require dotenv/config src/db/migrate.ts dotenv_config_path=../../.env",
    "db:seed": "ts-node --require dotenv/config src/db/seed.ts dotenv_config_path=../../.env"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.1",
    "@types/pdfkit": "^0.17.5",
    "aws-sdk": "^2.1550.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "twilio": "^5.13.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
