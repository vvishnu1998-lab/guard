# ============================================================
# GUARD — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# ----- API Server -----
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# ----- PostgreSQL -----
DATABASE_URL=postgresql://postgres:password@localhost:5432/guard

# ----- JWT -----
JWT_SECRET=change_me_at_least_64_chars_random_string_here
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens

# ----- Vishnu Super Admin (not stored in DB) -----
VISHNU_EMAIL=vishnu@example.com
VISHNU_PASSWORD_HASH=bcrypt_hash_of_vishnu_password

# ----- AWS S3 -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=guard-media-uploads

# ----- SendGrid -----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@guard.example.com

# ----- Twilio (SMS self-service unlock OTP) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_OTP_TTL_MINUTES=10

# ----- Firebase (FCM push notifications) -----
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ----- Web App -----
NEXT_PUBLIC_API_URL=http://localhost:3001
CLIENT_PORTAL_URL=http://localhost:3000/client

# ----- Mobile App (Expo public vars) -----
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
